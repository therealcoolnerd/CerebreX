{
  "name": "cerebrex",
  "version": "0.9.4",
  "description": "CerebreX CLI — The open-source Agent Infrastructure OS",
  "bin": {
    "cerebrex": "dist/index.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --minify",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 ./src/index.ts --outfile ./dist/cerebrex-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 ./src/index.ts --outfile ./dist/cerebrex-linux-arm64",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 ./src/index.ts --outfile ./dist/cerebrex-windows-x64.exe",
    "dev": "bun run --watch ./src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "homepage": "https://therealcool.site",
  "bugs": {
    "url": "https://github.com/arealcoolco/CerebreX/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arealcoolco/CerebreX.git",
    "directory": "apps/cli"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@cerebrex/core": "workspace:*",
    "@cerebrex/registry": "workspace:*",
    "@cerebrex/types": "workspace:*"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "agents": "^0.7.9",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "inquirer": "^13.3.2",
    "ora": "^9.3.0",
    "tar": "^7.4.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
