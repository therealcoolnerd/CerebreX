{
  "name": "cerebrex",
  "version": "0.2.0",
  "description": "CerebreX CLI — The open-source Agent Infrastructure OS",
  "bin": {
    "cerebrex": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --minify",
    "dev": "bun run --watch ./src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/therealcoolnerd/CerebreX.git",
    "directory": "apps/cli"
  },
  "license": "Apache-2.0"
}
